<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    
    <display-name>Mark Management System</display-name>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
    <servlet>
        <servlet-name>AddMarkServlet</servlet-name>
        <servlet-class>com.servlet.AddMarkServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddMarkServlet</servlet-name>
        <url-pattern>/AddMarkServlet</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>UpdateMarkServlet</servlet-name>
        <servlet-class>com.servlet.UpdateMarkServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateMarkServlet</servlet-name>
        <url-pattern>/UpdateMarkServlet</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>DeleteMarkServlet</servlet-name>
        <servlet-class>com.servlet.DeleteMarkServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteMarkServlet</servlet-name>
        <url-pattern>/DeleteMarkServlet</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>DisplayMarksServlet</servlet-name>
        <servlet-class>com.servlet.DisplayMarksServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DisplayMarksServlet</servlet-name>
        <url-pattern>/DisplayMarksServlet</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>com.servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/ReportServlet</url-pattern>
    </servlet-mapping>
</web-app>